# Backend environment variables (Spring Boot)
#
# Copy this file to `backend.env` (gitignored) and load before running:
#   export $(grep -v '^#' backend.env | xargs)   # bash/zsh — review before running
# Or set the same variables in your IDE run configuration / shell profile.
#
# Never commit `backend.env` with real production credentials.

# --- MySQL ---
DB_HOST=localhost
DB_PORT=3306
DB_NAME=inventoryflow
DB_USER=root
# Leave empty only if your local MySQL user has no password (not recommended).
DB_PASS=

# --- JWT (HS256 requires >= 32 ASCII characters) ---
# Generate a random value for anything beyond local dev.
INVENTORYFLOW_JWT_SECRET=change-me-to-a-long-random-string-min-32-chars!

# Optional
INVENTORYFLOW_JWT_EXPIRATION_MS=86400000
INVENTORYFLOW_JWT_ISSUER=inventoryflow-api
