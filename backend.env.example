# Backend environment variables (Spring Boot)
#
# Copy to `backend.env` (gitignored) or set in Railway / your host dashboard.
# Never commit real production secrets.
#
# Local load example (bash/zsh — review before running):
#   set -a && source backend.env && set +a

# --- Server ---
# Railway sets PORT automatically; optional locally.
PORT=8080

# Spring profile: use `prod` for Railway / production-like runs.
# SPRING_PROFILES_ACTIVE=prod

# --- MySQL (local or generic) ---
DB_HOST=localhost
DB_PORT=3306
DB_NAME=inventoryflow
DB_USER=root
DB_PASS=
# Local dev: false. Managed MySQL (e.g. Railway): usually true.
DB_USE_SSL=false

# --- MySQL (Railway plugin — optional; used when MYSQL* are set) ---
# MYSQLHOST=
# MYSQLPORT=
# MYSQLDATABASE=
# MYSQLUSER=
# MYSQLPASSWORD=

# --- JWT (HS256 requires >= 32 ASCII characters) ---
INVENTORYFLOW_JWT_SECRET=change-me-to-a-long-random-string-min-32-chars!

# Optional
INVENTORYFLOW_JWT_EXPIRATION_MS=86400000
INVENTORYFLOW_JWT_ISSUER=inventoryflow-api

# --- CORS (comma-separated origins; no trailing slashes) ---
# Local: leave empty to allow localhost dev only (plus patterns below).
# Production: set to your Vercel URL, e.g. https://inventoryflow.vercel.app
# INVENTORYFLOW_CORS_ORIGINS=https://your-app.vercel.app

# --- Demo seed data (empty DB only; idempotent) ---
# Local default: true via application.properties. In prod profile: defaults false — set true once for demos.
# INVENTORYFLOW_SEED_DATA=true
